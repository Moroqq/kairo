{
  "$schema": "https://schema.tauri.app/config/2/capability.json",
  "identifier": "default",
  "description": "Default app capabilities",
  "platforms": ["linux", "macOS", "windows", "android"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "notification:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-load",
    "store:allow-save",
    "store:allow-clear",
    "store:allow-has",
    "deep-link:default"
  ]
}
