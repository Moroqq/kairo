{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kairo",
  "version": "0.4.3",
  "identifier": "com.kairo.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kairo",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "maximized": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        { "scheme": ["kairo"] }
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFODM1NjhCOTI2RTM0NQpSV1JGNHlhNWFEWG9DbGQ4SGZ6VWZzTkk4b3dCUytJTjh0QTY4SmYvd0o0aWxqNU01N083a21nUwo=",
      "endpoints": [
        "https://kairogoupyrlife.duckdns.org/update/latest.json"
      ]
    }
  }
}
